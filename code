import sqlite3

CREATE_GAMES_TABLE = "CREATE TABLE IF NOT EXISTS games (id INTEGER PRIMARY KEY, name TEXT, genre TEXT, year INTEGER);"

INSERT_GAME = 'INSERT INTO games (name, genre, year) VALUES (?, ?, ?);'

GET_ALL_GAMES = 'SELECT * FROM games;'
GET_GAMES_BY_NAME = 'SELECT * FROM games WHERE name = ?;'
GET_GAMES_BY_GENRE = 'SELECT * FROM games WHERE genre =?;'
GET_GAMES_BY_YEAR_RANGE = 'SELECT * FROM games WHERE year BETWEEN ? AND ?'
GET_GAME_GENRE = '''
    SELECT * FROM games
    WHERE name = ?
    ORDER BY year DESC
    LIMIT 1;'''

DELETE_GAME_BY_ID = '''
DELETE FROM games2
WHERE id = ?
'''

DELETE_GAME_BY_NAME = '''
DELETE FROM games
WHERE name = ?
'''


def connect():
    return sqlite3.connect('data.db')

def create_tables(connection):
    with connection:
        connection.execute(CREATE_GAMES_TABLE)

def add_game(connection, name, genre, year):
    with connection:
        connection.execute(INSERT_GAME, (name, genre, year))

def get_all_games(connection):
    with connection:
        return connection.execute(GET_ALL_GAMES).fetchall()

def get_games_by_name(connection, name):
    with connection:
        return connection.execute(GET_GAMES_BY_NAME, (name,)).fetchall()

def get_games_by_genre(connection, genre):
    with connection:
        return connection.execute(GET_GAMES_BY_GENRE, (genre,)).fetchall()

def get_games_by_year_range(connection, min_year, max_year):
    with connection:
        return connection.execute(GET_GAMES_BY_YEAR_RANGE, (min_year, max_year)).fetchall()

def get_game_genre(connection, name):
    with connection:
        return connection.execute(GET_GAME_GENRE, (name,)).fetchone()

def delete_game_by_id(connection, id):
    with connection:
        connection.execute(DELETE_GAME_BY_ID, (id,))

def delete_game_by_name(connection, name):
    with connection:
        connection.execute(DELETE_GAME_BY_NAME, (name,))




